rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to safely check if a document exists and get its data
    function getRolesData() {
      return exists(/databases/$(database)/documents/system/roles) 
        ? get(/databases/$(database)/documents/system/roles).data 
        : {"adminEmails": [], "auditorEmails": []};
    }

    // Helper to check for Super Admin (Secure Claims + Document Fallback for Test/Local)
    function isSuperAdmin() {
      return request.auth != null && (
        request.auth.token.get('email', '') == 'jayshong@gmail.com' ||
        request.auth.token.get('isSuperAdmin', false) == true ||
        (exists(/databases/$(database)/documents/system/roles) && 
         request.auth.token.get('email', '') in get(/databases/$(database)/documents/system/roles).data.get('adminEmails', [])) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isSuperAdmin', false) == true)
      );
    }

    // Role partitioning helpers
    function isCustomerSuccess() {
      return request.auth != null && (
        isSuperAdmin() || 
        request.auth.token.get('isCustomerSuccess', false) == true ||
        (exists(/databases/$(database)/documents/system/merchant_roles) && 
         request.auth.token.email in get(/databases/$(database)/documents/system/merchant_roles).data.get('emails', [])) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isCustomerSuccess', false) == true)
      );
    }
    
    function isAuditor() {
      return request.auth != null && (
        isSuperAdmin() || 
        request.auth.token.get('isAuditor', false) == true ||
        (exists(/databases/$(database)/documents/system/compliance_roles) && 
         request.auth.token.email in get(/databases/$(database)/documents/system/compliance_roles).data.get('emails', [])) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAuditor', false) == true)
      );
    }
    function isSteward(bizId) {
      return request.auth != null && (
        exists(/databases/$(database)/documents/businesses/$(bizId)) && (
          get(/databases/$(database)/documents/businesses/$(bizId)).data.get('ownerEmail', '') == request.auth.token.email ||
          request.auth.token.email in get(/databases/$(database)/documents/businesses/$(bizId)).data.get('stewardship', {}).get('managers', []) ||
          request.auth.token.email in get(/databases/$(database)/documents/businesses/$(bizId)).data.get('stewardship', {}).get('crew', []) ||
          isCustomerSuccess() ||
          isAuditor()
        )
      );
    }

    // Users Collection - Protect PII & Role Fields
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId || 
        isCustomerSuccess() || 
        isAuditor() ||
        (
          exists(/databases/$(database)/documents/gratitude_bond_transfer/$(request.auth.uid + "_" + userId)) &&
          get(/databases/$(database)/documents/gratitude_bond_transfer/$(request.auth.uid + "_" + userId)).data.expiresAt > request.time
        )
      );
      allow update: if request.auth != null && request.auth.uid == userId && 
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'isAuditor', 'isCustomerSuccess', 'isSuperAdmin', 'isFlagged']);
      allow create: if request.auth != null && request.auth.uid == userId;

      // Allow access to sub-collections (counters, seasons, etc.)
      match /{allPaths=**} {
        allow read: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
        // System-critical stats (counters, seasons) must NOT be writable by the user
        allow write: if isSuperAdmin();
      }
      
      // Explicitly allow users to manage their own settings/profile data if needed, 
      // but NOT the system-generated stats sub-collections.
      match /settings/{docId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      }

      // Allow users to record their own scan sentinel state (rate limiting)
      match /sentinel/{docId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      }
    }
    
    // Role Documents - Partitioned Visibility
    match /system/roles {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }
    match /system/merchant_roles {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }
    match /system/compliance_roles {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }
    match /system/stats {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    
    // Business Directory
    match /businesses/{bizId} {
      allow read: if true;
      allow write: if isCustomerSuccess() || isAuditor();
      allow update: if request.auth != null && 
                    (request.auth.token.email == resource.data.ownerEmail || isCustomerSuccess() || isAuditor()) &&
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['score', 'status', 'isVerified', 'ownerEmail', 'id']);
      
      // Partitioned Transaction Ledger (Merchant Queue)
      match /transactions/{txnId} {
        allow read: if isSteward(bizId);
        allow write: if false; // System only via Cloud Functions
      }

      // Intelligence Center (Business Aggregates)
      match /intelligence/latest {
        allow read: if isSteward(bizId);
        allow write: if false; // System only via Cloud Functions
      }
    }
    
    // Transactions - Private Data
    match /transactions/{txnId} {
      // Only owners, customer success assistants (for support), or auditors can see raw transaction data
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        isCustomerSuccess() || 
        isAuditor() ||
        isSteward(resource.data.bizId)
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      // Users can edit their own pending logs. Admins can manage any.
      allow update: if request.auth != null && (
        (request.auth.uid == resource.data.userId && resource.data.status == 'pending') ||
        isCustomerSuccess() || 
        isAuditor() ||
        isSteward(resource.data.bizId)
      );
      allow delete: if isCustomerSuccess() || isAuditor() || isSteward(resource.data.bizId);
    }

    // Newsreel / Network Pulse Feed
    match /network_pulse/{actId} {
      allow read: if true;
      allow write: if false; // System only via Cloud Functions
    }
    
    // Audit Logs (Used by Audit Hub)
    match /compliance_logs/{logId} {
      allow read: if true;
      allow create: if isAuditor() || isSuperAdmin();
      allow update: if (isAuditor() || isSuperAdmin()) && resource.data.status != 'approved';
      allow delete: if isSuperAdmin();
    }
    
    // System Audit Trail (Public Transparency)
    match /audit_logs/{logId} {
      allow read: if true; 
      allow write: if isSuperAdmin() || isAuditor();
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isCustomerSuccess() || isAuditor();
    }

    // Initiatives, Privileges, Supervisions
    match /initiatives/{initId} { allow read: if true; allow write: if isCustomerSuccess() || isAuditor(); }
    match /privileges/{privId} { allow read: if true; allow write: if isCustomerSuccess() || isAuditor(); }
    match /supervisions/{supId} { allow read: if true; allow write: if isSuperAdmin(); }

    // Institutional Audit Workflow
    match /audit_submissions/{submissionId} {
      allow read: if request.auth != null && (
        resource.data.auditorId == request.auth.uid || 
        isSuperAdmin() || isAuditor()
      );
      allow create: if request.auth != null && isAuditor() && request.resource.data.status == 'draft';
      allow update: if request.auth != null && (
        (resource.data.auditorId == request.auth.uid && resource.data.status == 'draft') ||
        (isSuperAdmin() && resource.data.status == 'review')
      );
      allow delete: if isSuperAdmin();
    }

    // Consumer Feedback
    match /feedback/{feedbackId} {
      allow create, read: if true; // Allow guests and users to read counts/recommendations
      allow update, delete: if isAuditor() || isSuperAdmin();
    }

    // User Applications
    match /applications/{appId} {
      allow read: if request.auth != null && (
        request.auth.token.email == resource.data.email || 
        isCustomerSuccess()
      );
      allow create: if request.auth != null && request.auth.token.email == request.resource.data.email;
      allow update: if request.auth != null && (
        (request.auth.token.email == resource.data.email && resource.data.status != 'approved') ||
        isCustomerSuccess()
      );
      allow delete: if request.auth != null && (
        isCustomerSuccess() || request.auth.token.email == resource.data.email
      );
    }

    // Gratitude Bonds (Business Intelligence & User Relationship)
    match /users/{userId}/gratitude_bonds/{bizId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId || 
        isSteward(bizId)
      );
      allow write: if false; // System only via Cloud Functions
    }

    match /gratitude_bond_transfer/{bondId} {
      allow read: if request.auth != null && (
        (request.auth.uid == resource.data.userId || isSteward(resource.data.bizId)) &&
        resource.data.expiresAt > request.time
      );
      allow write: if false; // System only via Cloud Functions
    }
  }
}
