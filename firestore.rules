rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to safely check if a document exists and get its data
    function getRolesData() {
      return exists(/databases/$(database)/documents/system/roles) 
        ? get(/databases/$(database)/documents/system/roles).data 
        : {"adminEmails": [], "auditorEmails": []};
    }

    // Check if the user is a super admin
    function isSuperAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'jayshong@gmail.com' ||
        request.auth.token.email in getRolesData().adminEmails
      );
    }
    
    // Check if the user is an auditor or super admin
    function isAuditor() {
      return request.auth != null && (
        request.auth.token.email == 'jayshong@gmail.com' ||
        request.auth.token.email in getRolesData().auditorEmails ||
        isSuperAdmin()
      );
    }

    // Users Collection - Protect PII by restricting reads
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // System Configurations - Only super admin can edit
    match /system/{docId} {
      allow read: if true; 
      allow write: if isSuperAdmin();
    }
    
    // Business Directory
    match /businesses/{bizId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isAuditor();
      
      // Allow owners to update their own profile (restricted fields)
      allow update: if request.auth != null && 
                    request.auth.token.email == resource.data.ownerEmail &&
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['score', 'status', 'isVerified', 'ownerEmail', 'id']);
    }
    
    // Transactions / Logged activities
    match /transactions/{txnId} {
      allow read: if true;
      // Allow user to create pending transactions if userId matches their auth uid
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      // Changing status to verified/returned, etc.
      allow update, delete: if isSuperAdmin() || isAuditor();
    }
    
    // Audit Logs Collection
    match /compliance_logs/{logId} {
      allow read: if true;
      allow create: if isAuditor() || isSuperAdmin();
      // Auditors can edit until approved. Once approved, it is locked.
      allow update: if (isAuditor() || isSuperAdmin()) && resource.data.status != 'approved';
      allow delete: if isSuperAdmin();
    }

    // Announcements Collection
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Initiatives Collection
    match /initiatives/{initId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isAuditor();
    }

    // Privileges Collection
    match /privileges/{privId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isAuditor();
    }

    // Audit Submissions Collection (Draft -> Review -> Published Workflow)
    match /audit_submissions/{submissionId} {
      allow read: if request.auth != null && (
        resource.data.auditorId == request.auth.uid || 
        isSuperAdmin() || 
        isAuditor()
      );
      
      // Allow creation of drafts for auditors
      allow create: if request.auth != null && isAuditor() && request.resource.data.status == 'draft';
      
      // Update rules:
      // - Auditor can update their own drafts
      // - Auditor can submit for review (draft -> review)
      // - Supervisor can update any review
      // - Supervisor can publish (review -> published)
      allow update: if request.auth != null && (
        (resource.data.auditorId == request.auth.uid && resource.data.status == 'draft') ||
        (isSuperAdmin() && resource.data.status == 'review')
      );
      
      allow delete: if isSuperAdmin();
    }

    // Supervisions Collection (Links auditors to supervisors)
    match /supervisions/{supId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
  }
}
