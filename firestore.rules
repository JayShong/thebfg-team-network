rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to safely check if a document exists and get its data
    function getRolesData() {
      return exists(/databases/$(database)/documents/system/roles) 
        ? get(/databases/$(database)/documents/system/roles).data 
        : {"adminEmails": [], "auditorEmails": []};
    }

    // Helper to check for Super Admin (Secure Claims first)
    function isSuperAdmin() {
      return request.auth != null && (
        request.auth.token.isSuperAdmin == true || 
        request.auth.token.email == 'jayshong@gmail.com'
      );
    }

    // Role partitioning helpers
    function isMerchantAssistant() {
      return request.auth != null && (
        isSuperAdmin() || 
        request.auth.token.isCustomerSuccess == true ||
        request.auth.token.email in get(/databases/$(database)/documents/system/merchant_roles).data.emails
      );
    }
    
    function isAuditor() {
      return request.auth != null && (
        isSuperAdmin() || 
        request.auth.token.isAuditor == true ||
        request.auth.token.email in get(/databases/$(database)/documents/system/compliance_roles).data.emails
      );
    }

    // Users Collection - Protect PII & Role Fields
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isMerchantAssistant() || isAuditor());
      allow update: if request.auth != null && request.auth.uid == userId && 
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'isAuditor', 'isMerchantAssistant', 'isSuperAdmin', 'isFlagged']);
      allow create: if request.auth != null && request.auth.uid == userId;

      // Allow access to sub-collections (counters, seasons, etc.)
      match /{allPaths=**} {
        allow read: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
        // System-critical stats (counters, seasons) must NOT be writable by the user
        allow write: if isSuperAdmin();
      }
      
      // Explicitly allow users to manage their own settings/profile data if needed, 
      // but NOT the system-generated stats sub-collections.
      match /settings/{docId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      }
    }
    
    // Role Documents - Partitioned Visibility
    match /system/merchant_roles {
      allow read: if isMerchantAssistant() || isSuperAdmin();
      allow write: if isSuperAdmin();
    }
    match /system/compliance_roles {
      allow read: if isAuditor() || isSuperAdmin();
      allow write: if isSuperAdmin();
    }
    match /system/stats {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    
    // Business Directory
    match /businesses/{bizId} {
      allow read: if true;
      allow write: if isMerchantAssistant() || isAuditor();
      allow update: if request.auth != null && 
                    request.auth.token.email == resource.data.ownerEmail &&
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['score', 'status', 'isVerified', 'ownerEmail', 'id']);
    }
    
    // Transactions - Private Data
    match /transactions/{txnId} {
      // Only owners, merchant assistants (for support), or auditors can see raw transaction data
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        isMerchantAssistant() || 
        isAuditor()
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      // Users can edit their own pending logs. Admins can manage any.
      allow update: if request.auth != null && (
        (request.auth.uid == resource.data.userId && resource.data.status == 'pending') ||
        isMerchantAssistant() || 
        isAuditor()
      );
      allow delete: if isMerchantAssistant() || isAuditor();
    }

    // Newsreel / Public Activity Feed
    match /public_activity/{actId} {
      allow read: if true;
      allow write: if false; // System only via Cloud Functions
    }
    
    // Audit Logs (Used by Audit Hub)
    match /compliance_logs/{logId} {
      allow read: if true;
      allow create: if isAuditor() || isSuperAdmin();
      allow update: if (isAuditor() || isSuperAdmin()) && resource.data.status != 'approved';
      allow delete: if isSuperAdmin();
    }
    
    // Alias for legacy audit_logs collection
    match /audit_logs/{logId} {
      allow read: if request.auth != null && (isAuditor() || isSuperAdmin());
      allow write: if isSuperAdmin() || isAuditor();
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isMerchantAssistant() || isAuditor();
    }

    // Initiatives, Privileges, Supervisions
    match /initiatives/{initId} { allow read: if true; allow write: if isMerchantAssistant() || isAuditor(); }
    match /privileges/{privId} { allow read: if true; allow write: if isMerchantAssistant() || isAuditor(); }
    match /supervisions/{supId} { allow read: if true; allow write: if isSuperAdmin(); }

    // Institutional Audit Workflow
    match /audit_submissions/{submissionId} {
      allow read: if request.auth != null && (
        resource.data.auditorId == request.auth.uid || 
        isSuperAdmin() || isAuditor()
      );
      allow create: if request.auth != null && isAuditor() && request.resource.data.status == 'draft';
      allow update: if request.auth != null && (
        (resource.data.auditorId == request.auth.uid && resource.data.status == 'draft') ||
        (isSuperAdmin() && resource.data.status == 'review')
      );
      allow delete: if isSuperAdmin();
    }

    // Consumer Feedback
    match /feedback/{feedbackId} {
      allow create: if true; // Allow guests and users to submit observations
      allow read, update, delete: if isAuditor() || isSuperAdmin();
    }
  }
}
